# ─────────────────────────────────────────────────────────────────────────────
# Research Paper Agent — Environment Variables
# Copy this file to .env and fill in your actual API keys.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API — Primary LLM provider (router, synthesiser, summariser, guardrail)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Cohere API — Used for Rerank v3 (re-scoring retrieved document chunks)
# Get your key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-api-key-here

# Tavily API — Web search optimised for LLM pipelines (Web Agent)
# Get your key at: https://app.tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# LangSmith API — Observability & tracing for every LangGraph run (optional)
# Get your key at: https://smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key-here

# LangSmith project name (optional — defaults to "default" if not set)
LANGCHAIN_PROJECT=research-paper-agent

# Enable LangSmith tracing: set to "true" to activate, "false" to disable
LANGCHAIN_TRACING_V2=true
